    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "nestjs-pino": "^4.1.0",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "uuidv7": "^1.0.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "overrides": {
    "qs": "^6.14.0",
    "multer": "^2.0.2"
