# Şablon — gerçek değerler asla repo'ya girmez (docs/28 §5).
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://dockly:dockly@localhost:5432/dockly_dev
REDIS_URL=redis://localhost:6379
LOG_LEVEL=debug
SHUTDOWN_TIMEOUT_MS=10000
# Auth (Faz 2.1) — gerçek değerler SSM'den (docs/28 §5); yerelde test anahtarı üret:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt.pem
#   openssl pkey -in jwt.pem -pubout -out jwt.pub
FIREBASE_PROJECT_ID=dockly-dev
JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_KID=dockly-k1
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_DAYS=60
AUTH_RATE_LIMIT_PER_MIN=10
